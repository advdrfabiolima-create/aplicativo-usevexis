{
  "version": 2,
  "name": "vexis",
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/public/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/public/$1"
    },
    {
      "src": "/src/(.*)",
      "headers": { "cache-control": "public, max-age=86400" },
      "dest": "/src/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
